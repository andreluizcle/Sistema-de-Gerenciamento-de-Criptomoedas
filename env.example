# =============================================================================
# FT-Coin - Configuracao do banco de dados (modelo)
# =============================================================================
# Copie este arquivo para .env (sem o .example) na raiz do projeto e
# preencha com os valores reais. O arquivo .env NAO deve ser versionado
# - ele ja esta listado no .gitignore.
#
# As chaves abaixo sao lidas em tempo de execucao pela classe
# br.unicamp.ftcoin.util.EnvLoader e usadas por DatabaseConnection.
# Tambem podem ser definidas como variaveis de ambiente do sistema
# operacional (estas tem prioridade sobre o arquivo .env).
# =============================================================================

# Endereco do servidor MariaDB
DB_HOST=143.106.243.64

# Porta TCP do MariaDB (padrao 3306)
DB_PORT=3306

# Nome do banco (schema)
DB_NAME=PooI_1s26_B03

# Usuario com permissao de leitura/escrita no banco
DB_USER=PooI_1s26_B03

# Senha do usuario - NUNCA commitar valor real
DB_PASSWORD=sua_senha_aqui
